# name: test/sql/fingerprints.test
# group: [vgi_tlsfp]
#
# End-to-end SQL coverage of the tlsfp worker through the real DuckDB `vgi`
# extension: JA3 / JA3S / JA4 over raw handshake bytes, the *_from_parts modes
# (asserted to agree with the bytes modes), parse_client_hello, the
# is_tls_handshake guard, and the GROUP BY clustering shape from the spec.
#
# The BLOB fixtures are a canonical FoxIO-JA4 ClientHello (fingerprints to
# t13d1516h2_8daaf6152771_e5627efa2ab1) and a small ServerHello.

require-env VGI_TLSFP_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'tlsfp' AS tlsfp (TYPE vgi, LOCATION '${VGI_TLSFP_WORKER}');

statement ok
SET search_path = 'tlsfp.main';

# NOTE: the parameterless tlsfp_version() scalar was removed (VGI328); the
# running build version is now published as the catalog's implementation_version
# (read from vgi_catalogs()), so it no longer spends a query slot on the surface.

# ---- JA4 over raw ClientHello bytes: the published canonical fingerprint ----
query I
SELECT ja4(from_hex(''));
----
t13d1516h2_8daaf6152771_e5627efa2ab1

# ---- JA4_r (un-hashed) form ------------------------------------------------
query I
SELECT ja4_raw(from_hex(''));
----
t13d1516h2_002f,0035,009c,009d,1301,1302,1303,c013,c014,c02b,c02c,c02f,c030,cca8,cca9_0005,000a,000b,000d,0012,0015,0017,001b,0023,002b,002d,0033,4469,ff01_0403,0804,0401,0503,0805,0501,0806,0601

# ---- JA3 over the same bytes ----------------------------------------------
query I
SELECT ja3(from_hex(''));
----
d073ecbd407a031c76ecda2e9c168b98

# ---- JA3 pre-hash string ---------------------------------------------------
query I
SELECT ja3_string(from_hex(''));
----
771,47-53-156-157-4865-4866-4867-49171-49172-49195-49196-49199-49200-52392-52393,0-5-10-11-13-16-18-21-23-27-35-43-45-51-17513-65281,29-23-24-25,0

# ---- JA3S over a ServerHello ----------------------------------------------
query I
SELECT ja3s(from_hex('020000360303222222222222222222222222222222222222222222222222222222222222222200c02f00000eff01000100001000050003026832'));
----
7bee5c1d424b7e5f943b06983bb11422

# ---- bytes mode and parts mode AGREE (JA3) --------------------------------
# Same ClientHello, fed as already-extracted fields (GREASE 2570/6682 included
# to prove stripping matches the bytes path).
query I
SELECT ja3_from_parts(
         771,
         [2570,47,53,156,157,4865,4866,4867,49171,49172,49195,49196,49199,49200,52392,52393],
         [0,5,10,11,13,16,18,21,23,27,6682,35,43,45,51,17513,65281],
         [29,23,24,25],
         [0])
       = ja3(from_hex(''));
----
true

# ---- bytes mode and parts mode AGREE (JA4) --------------------------------
query I
SELECT ja4_from_parts(
         772,
         [2570,47,53,156,157,4865,4866,4867,49171,49172,49195,49196,49199,49200,52392,52393],
         [0,5,10,11,13,16,18,21,23,27,6682,35,43,45,51,17513,65281],
         [1027,2052,1025,1283,2053,1281,2054,1537],
         'h2')
       = ja4(from_hex(''));
----
true

# ---- JA3S parts mode ------------------------------------------------------
query I
SELECT ja3s_from_parts(771, 49199, [65281, 16]);
----
7bee5c1d424b7e5f943b06983bb11422

# ---- parse_client_hello decode --------------------------------------------
query I
SELECT (parse_client_hello(from_hex(''))).sni;
----
example.com

# ---- guard + per-row NULL safety on malformed bytes -----------------------
query II
SELECT is_tls_handshake(from_hex('deadbeef')), ja3(from_hex('deadbeef'));
----
false	NULL

query I
SELECT ja4(NULL);
----
NULL

# ---- GROUP BY clustering shape (the spec's headline query) ----------------
# Three handshakes: two identical canonical ClientHellos + one junk row. The
# canonical fingerprint clusters with n=2; junk yields NULL.
query III
WITH captured_handshakes(client_hello) AS (
  VALUES
    (from_hex('')),
    (from_hex('')),
    (from_hex('00'))
)
SELECT ja3(client_hello) AS ja3, ja4(client_hello) AS ja4, count(*) AS n
FROM captured_handshakes
GROUP BY 1, 2
ORDER BY n DESC;
----
d073ecbd407a031c76ecda2e9c168b98	t13d1516h2_8daaf6152771_e5627efa2ab1	2
NULL	NULL	1

statement ok
USE memory;

statement ok
DETACH tlsfp;
